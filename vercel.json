{
  "builds": [
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "*.css",
      "use": "@vercel/static"
    },
    {
      "src": "*.js",
      "use": "@vercel/static"
    },
    {
      "src": "image/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/register.html"
    },
    {
      "src": "/register.html",
      "dest": "/register.html"
    },
    {
      "src": "/profile.html",
      "dest": "/profile.html"
    },
    {
      "src": "/index.css",
      "dest": "/index.css"
    },
    {
      "src": "/register.js",
      "dest": "/register.js"
    },
    {
      "src": "/profile.js",
      "dest": "/profile.js"
    },
    {
      "src": "/image/(.*)",
      "dest": "/image/$1"
    }
  ]
}
